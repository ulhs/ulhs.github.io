# IDE and Editor files
.windsurf/
.trae/
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs and runtime files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Optional: Build outputs (if you add build tools later)
dist/
build/
_site/

# Temporary files
*.tmp
*.temp

# Node.js dependencies (if you add package.json later)
node_modules/

# === School Data Security (DPA 2012 Compliance) ===

# Ignore any filled SF2 forms or student lists
*sf2_filled*
*attendance_report*
*student_data*
*.xlsx
*.csv
*.pdf

# Allow ONLY the blank template (example: assets/templates/SF2_Blank.xlsx)
# This uses a "negation" rule: ignore all xlsx, but keep the template
!assets/admin/attendance/templates/SF2_Blank.xlsx
!assets/admin/attendance/templates/SF2_Blank_SHS.xlsx

# Ignore local environment variables (where you store Supabase/Firebase API Keys)
.env
.env.local
.env.*.local

# Ignore any logs or temporary data exports
logs/
*.log
tmp/
dist/
